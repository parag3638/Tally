# ============================================================================
#  AI Expense Tracker — environment configuration
#  Copy to .env and fill in. Defaults match docker-compose.yml.
# ============================================================================

# ---- Application ----
APP_ENV=development                 # development | production | test
LOG_LEVEL=INFO
LOG_JSON=false                      # true -> structured JSON logs (prod)

# ---- Database (psycopg2 app pool + psycopg3 checkpointer share this DB) ----
PGHOST=localhost
PGPORT=5432
PGDATABASE=expenses
PGUSER=expenses
PGPASSWORD=expenses
DB_POOL_MIN=1
DB_POOL_MAX=10

# Dedicated read-only role used by the text-to-SQL agent (Phase 5).
# Falls back to PGUSER if unset, but a real read-only role is strongly recommended.
PG_READONLY_USER=expenses_readonly
PG_READONLY_PASSWORD=readonly

# ---- Redis / background worker ----
REDIS_URL=redis://localhost:6379/0

# ---- Auth ----
JWT_SECRET=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# ---- AI providers ----
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Model roles (override to swap providers). Multi-model fallback uses these in order.
VISION_MODEL=gpt-4o
VISION_FALLBACK_MODEL=claude-3-7-sonnet-20250219
CATEGORIZER_MODEL=gpt-4o-mini
CATEGORIZER_FALLBACK_MODEL=claude-3-5-haiku-20241022
CHAT_MODEL=gpt-4o
INSIGHTS_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Confidence gate: receipts at/above this auto-persist; below routes to human review.
AUTO_ACCEPT_THRESHOLD=0.85
# Cosine distance below this (with amount/date match) flags a possible duplicate.
DUPLICATE_DISTANCE_THRESHOLD=0.15

# ---- LangSmith (observability + evals) ----
LANGCHAIN_TRACING_V2=false
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=ai-expense-tracker

# ---- Receipt file storage (mounted volume in Docker) ----
RECEIPT_STORAGE_DIR=./data/receipts

# ---- MCP server (Phase 7): which user the MCP tools act as ----
MCP_USER_ID=1
